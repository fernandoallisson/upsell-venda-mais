                                    "description": "Colunas para exportar, separadas por v\u00edrgula. Se n\u00e3o informado, usa as colunas padr\u00e3o (email, first_name, last_name, phone, total_orders_count, lifetime_value, average_ticket, last_purchase_at).",
                                    "disabled": false
                                },
                                {
                                    "key": "format",
                                    "value": "csv",
                                    "description": "Formato do arquivo. Valores aceitos: xlsx, csv. Default: csv (mais eficiente para streaming).",
                                    "disabled": false
                                }
                            ],
                            "raw": "{{baseUrl}}\/api\/v1\/segments\/:segment_id\/export\/stream?columns=email%2Cfirst_name%2Clast_name%2Clifetime_value&format=csv",
                            "variable": [
