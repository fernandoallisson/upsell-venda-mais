                        "method": "GET",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application\/json"
                            },
                            {
                                "key": "Accept",
                                "value": "application\/json"
                            }
                        ],
                        "body": null,
                        "description": "Faz o download do arquivo de exporta\u00e7\u00e3o gerado ap\u00f3s a conclus\u00e3o do job ass\u00edncrono.\n\nO arquivo ficar\u00e1 dispon\u00edvel por **24 horas** ap\u00f3s a conclus\u00e3o da exporta\u00e7\u00e3o.\nAp\u00f3s esse per\u00edodo, ser\u00e1 necess\u00e1rio iniciar uma nova exporta\u00e7\u00e3o."
                    },
                    "response": [
                        {
                            "header": [],
                            "code": 200,
                            "body": "{\n  \"description\": \"Arquivo bin\u00e1rio (XLSX ou CSV) retornado como download\"\n}",
