                                "value": "application\/json"
                            },
                            {
                                "key": "Accept",
                                "value": "application\/json"
                            }
                        ],
                        "body": null,
                        "description": "Lista todas as API Keys do tenant atual. A secret_key nunca \u00e9 retornada por seguran\u00e7a."
