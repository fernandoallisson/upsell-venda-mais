    "item": [
        {
            "name": "API Keys (Tenant)",
            "description": "Gerenciamento de chaves de API do tenant para autentica\u00e7\u00e3o de widgets e integra\u00e7\u00f5es.",
            "item": [
                {
                    "name": "Listar API Keys",
                    "request": {
                        "url": {
                            "host": "{{baseUrl}}",
                            "path": "api\/v1\/api-keys",
                            "query": [
                                {
                                    "key": "type",
                                    "value": "widget",
                                    "description": "Filtrar por tipo (widget, webhook, integration).",
                                    "disabled": false
                                },
                                {
                                    "key": "is_active",
                                    "value": "1",
                                    "description": "Filtrar apenas ativas\/inativas.",
                                    "disabled": false
                                }
                            ],
                            "raw": "{{baseUrl}}\/api\/v1\/api-keys?type=widget&is_active=1"
