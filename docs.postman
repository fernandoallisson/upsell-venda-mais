        {
            "name": "Widget & Public API",
            "description": "Endpoints p\u00fablicos do widget de upsell (autentica\u00e7\u00e3o via API Key)",
            "item": [
                {
                    "name": "Obter oferta ativa para um cliente.",
                    "request": {
                        "url": {
                            "host": "{{baseUrl}}",
                            "path": "api\/v1\/widget\/offer",
                            "query": [
                                {
                                    "key": "customer_id",
                                    "value": "16",
                                    "description": "ID do cliente (opcional).",
                                    "disabled": false
                                },
                                {
                                    "key": "email",
                                    "value": "gbailey%40example.net",
                                    "description": "Email do cliente (opcional).",
                                    "disabled": false
                                },
                                {
                                    "key": "fingerprint",
                                    "value": "architecto",
                                    "description": "UUID do visitante an\u00f4nimo (opcional).",
                                    "disabled": false
                                },
                                {
                                    "key": "product_id",
                                    "value": "16",
                                    "description": "ID do produto atual (opcional, para contexto).",
                                    "disabled": false
                                },
                                {
                                    "key": "cart_value",
                                    "value": "architecto",
                                    "description": "decimal Valor atual do carrinho (opcional).",
                                    "disabled": false
                                },
                                {
                                    "key": "type",
                                    "value": "architecto",
                                    "description": "Tipo de oferta: pre_checkout, post_purchase, cart_drawer (opcional).",
                                    "disabled": false
                                },
                                {
                                    "key": "location",
                                    "value": "architecto",
                                    "description": "Local de exibi\u00e7\u00e3o: product_page, side_cart, cart_page, pre_checkout, post_purchase (opcional).",
                                    "disabled": false
                                }
                            ],
                            "raw": "{{baseUrl}}\/api\/v1\/widget\/offer?customer_id=16&email=gbailey%40example.net&fingerprint=architecto&product_id=16&cart_value=architecto&type=architecto&location=architecto"
                        },
                        "method": "GET",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application\/json"
                            },
                            {
                                "key": "Accept",
                                "value": "application\/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\"customer_id\":16,\"email\":\"zbailey@example.net\",\"fingerprint\":\"i\",\"product_id\":16,\"cart_value\":4326.41688,\"type\":\"cart_drawer\",\"location\":\"post_purchase\"}"
                        },
                        "description": "Este endpoint retorna a melhor oferta dispon\u00edvel para um cliente espec\u00edfico\nbaseado em segmenta\u00e7\u00e3o, contexto de compra, local de exibi\u00e7\u00e3o e performance hist\u00f3rica."
                    },
                    "response": [
                        {
                            "header": [],
                            "code": 200,
                            "body": "{\n  \"offer_id\": 1,\n  \"campaign_id\": 1,\n  \"product_id\": 5,\n  \"headline\": \"Combo Especial\",\n  \"description\": \"Ganhe 30% de desconto neste produto\",\n  \"type\": \"post_purchase\",\n  \"discount_type\": \"percentage\",\n  \"discount_value\": 30,\n  \"product\": {\n    \"id\": 5,\n    \"name\": \"Produto Premium\",\n    \"image\": \"https:\/\/...\",\n    \"price\": \"99.90\",\n    \"variant_id\": \"12345\"\n  },\n  \"campaign\": {\n    \"headline\": \"Promo\u00e7\u00e3o de Ver\u00e3o\",\n    \"description\": \"Aproveite!\",\n    \"cta_text\": \"Adicionar\",\n    \"widget_css\": null,\n    \"widget_html\": null\n  }\n}",
                            "name": ""
                        },
                        {
                            "header": [],
                            "code": 404,
                            "body": "{\n  \"message\": \"Nenhuma oferta dispon\u00edvel no momento\"\n}",
                            "name": ""
                        }
