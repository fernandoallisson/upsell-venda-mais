                            "body": "{\n  \"data\": [\n    {\n      \"id\": 1,\n      \"name\": \"Widget Loja\",\n      \"public_key\": \"pk_a1b2c3d4e5f6g7h8\",\n      \"type\": \"widget\",\n      \"allowed_origins\": [\"https:\/\/minhaloja.com.br\"],\n      \"rate_limit\": 1000,\n      \"is_active\": true,\n      \"last_used_at\": \"2026-02-15T10:30:00.000000Z\",\n      \"created_at\": \"2026-01-10T08:00:00.000000Z\"\n    }\n  ],\n  \"links\": {},\n  \"meta\": {}\n}",
