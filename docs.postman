                {
                    "name": "Exporta\u00e7\u00e3o s\u00edncrona (streaming)",
                    "request": {
                        "url": {
                            "host": "{{baseUrl}}",
                            "path": "api\/v1\/segments\/:segment_id\/export\/stream",
